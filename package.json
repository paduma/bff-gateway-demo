{
  "name": "bff-gateway-demo",
  "version": "1.0.0",
  "description": "BFF gateway demo showcasing API aggregation, SSE proxy, caching, rate limiting, and graceful degradation",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:services": "tsx watch src/mock-services/index.ts",
    "dev:all": "concurrently -n \"bff,services\" -c \"blue,green\" \"npm run dev\" \"npm run dev:services\"",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "keywords": ["bff", "gateway", "api-aggregation", "sse", "rate-limiting"],
  "author": "Paduma",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "concurrently": "^8.2.2"
  }
}
